<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomePage</title>
</head>
<body>
    <h1>URL Generator</h1>
    
    <div style="display: flex; flex-direction: column; padding-top: 10vb;">
        <form action="/url" method="POST">
            <label for="">Enter Original url</label>
            <input type="text" placeholder="https://example.com" name="url"> 
            <button type="submit">Generate URL</button>
        </form>
        <div style="margin-top: 5vb;">
            <% if (locals.id) { %>
                <p> URL Generated: http://localhost:200/url/<%= id %></p>
            <% } %>
        </div>

        <div>
            <% if (locals.urls) { %>
                <table>
                    <thead>
                        <th>S. No &nbsp;</th>
                        <th> &nbsp;ShortId  </th>
                        <th> &nbsp; &nbsp;Redirect URLS</th>
                    </thead>
                    <tbody>
                        <% urls.forEach((url, index) => { %>
                            <td> &nbsp;<%= index + 1 %> </td>
                            <td><%= url.shortid %></td>
                            <td> &nbsp; &nbsp;<%= url.realUrl %></td>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </div>

    </div>


</body>
</html>